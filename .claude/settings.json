{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "Agent",
      "mcp__*",
      "Bash(git *)"
    ],
    "deny": []
  },
  "enabledMcpjsonServers": [
    "atlassian"
  ],
  "mcpServers": {
    "gdrive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-drive"]
    }
  }
}
